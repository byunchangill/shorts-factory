{
  "name": "yt-shorts-factory",
  "version": "0.1.0",
  "description": "리서치 기반 YouTube Shorts 자동 제작 파이프라인",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "tsx src/orchestrator.ts",
    "status": "tsx src/orchestrator.ts --status",
    "preflight": "tsx src/orchestrator.ts --dry-run",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.59.0",
    "dotenv": "^16.4.7",
    "googleapis": "^134.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
