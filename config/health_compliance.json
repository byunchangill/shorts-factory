{
  "version": "v6",
  "claimLevels": {
    "level_1_safe": {
      "description": "일반 상식, 널리 알려진 건강 정보",
      "allowed": true,
      "requiresDisclaimer": false,
      "auditAction": "allowed"
    },
    "level_2_conditional": {
      "description": "조건부 정보",
      "allowed": true,
      "requiresDisclaimer": true,
      "disclaimerType": "general",
      "auditAction": "allowed_with_disclaimer"
    },
    "level_3_caution": {
      "description": "효능 주장",
      "allowed": true,
      "requiresDisclaimer": true,
      "disclaimerType": "consult_professional",
      "requiredSuffix": "~라는 연구 결과가 있습니다",
      "auditAction": "allowed_with_suffix_and_disclaimer"
    },
    "level_4_prohibited": {
      "description": "단정적 의학 주장, 치료 효과, 진단",
      "allowed": false,
      "action": "reject_and_rewrite",
      "auditAction": "rewritten"
    }
  },
  "prohibitedPhrases": {
    "absolute_cure": {
      "matchType": "contains_keyword",
      "keywords": ["완치", "100% 효과", "무조건 낫는다", "기적의 치료", "완벽한 치료"],
      "severity": "critical",
      "action": "block",
      "rewrite": {
        "strategy": "fallback",
        "fallback": null
      }
    },
    "conspiracy": {
      "matchType": "contains_keyword",
      "keywords": ["의사가 숨기는", "제약회사가 감추는", "병원에서 안 알려주는", "의료계가 숨긴"],
      "severity": "critical",
      "action": "block",
      "rewrite": {
        "strategy": "fallback",
        "fallback": null
      }
    },
    "diagnosis_pattern": {
      "matchType": "template",
      "detect": {
        "templates": [
          "당신은 ${disease}입니다",
          "이 증상이면 ${disease}입니다",
          "이것은 ${disease}의 신호입니다",
          "${symptom}이면 ${disease}을 의심"
        ]
      },
      "rewrite": {
        "strategy": "full_sentence_replace",
        "template": "${disease} 관련 증상이 있다면 전문의 상담을 권장합니다",
        "fallback": "관련 증상이 있다면 전문의 상담을 권장합니다"
      },
      "severity": "high",
      "action": "rewrite_to_conditional"
    },
    "treatment_directive": {
      "matchType": "template",
      "detect": {
        "templates": [
          "반드시 ${action}하세요",
          "지금 당장 ${action}하세요",
          "이것만 ${action}하면"
        ]
      },
      "rewrite": {
        "strategy": "verb_stem_rewrite",
        "template": "${action_stem}하는 것을 고려해볼 수 있습니다",
        "stemRule": "캡처된 ${action}에서 어간 추출. 먹으→먹, 운동→운동",
        "fallback": "해당 방법을 고려해볼 수 있습니다"
      },
      "severity": "high",
      "action": "rewrite_to_suggestion"
    },
    "exaggeration": {
      "matchType": "exact_keyword",
      "keywords": ["기적", "마법", "만병통치", "놀라운 효과", "최강", "최고의 치료"],
      "severity": "medium",
      "action": "rewrite_to_neutral",
      "rewrite": {
        "strategy": "keyword_swap",
        "replacements": {
          "기적": "주목할 만한",
          "마법": "효과적인",
          "만병통치": "다양한 건강 이점이 알려진",
          "놀라운 효과": "긍정적인 효과",
          "최강": "효과가 좋은",
          "최고의 치료": "널리 알려진 방법"
        }
      }
    }
  },
  "matchTypeDefinitions": {
    "exact_keyword": {
      "description": "한국어 단어 경계 매칭",
      "method": "키워드 뒤에 허용된 조사/어미가 오면 매칭, 다른 한글이 이어지면 비매칭",
      "examples": {
        "기적→기적입니다": "매칭 (어미)",
        "기적→기적적인": "비매칭 (다른 단어)",
        "기적→기적이었다": "매칭 (어미)",
        "완치→완치율": "비매칭 (다른 단어)",
        "마법→마법처럼": "매칭 (조사)",
        "마법→마법사": "비매칭 (다른 단어)"
      }
    },
    "contains_keyword": {
      "description": "부분 문자열 매칭",
      "method": "sentence.includes(keyword)",
      "note": "주로 다단어 구문에 사용"
    },
    "template": {
      "description": "패턴 매칭 (검출) + 재작성 분리",
      "detectMethod": "특수문자 escape → ${var}를 non-greedy (.+?)로 변환 → regex 매칭",
      "rewriteMethod": "캡처 변수로 재작성 템플릿 채움. 실패 시 fallback 사용."
    }
  },
  "rewriteStrategies": {
    "full_sentence_replace": "문장 전체를 재작성 템플릿으로 교체. 캡처 변수 사용.",
    "verb_stem_rewrite": "캡처된 동사에서 어간 추출 후 재작성. 실패 시 fallback.",
    "keyword_swap": "키워드를 replacements의 대체어로 직접 교체.",
    "fallback": "고정 문구 사용 (캡처 불필요)."
  },
  "sourceCredibility": {
    "tier_1": {
      "description": "공인 기관 / 학술",
      "examples": ["WHO", "CDC", "식약처", "PubMed", "대한의학회"],
      "trustLevel": "high"
    },
    "tier_2": {
      "description": "의료 기관",
      "examples": ["서울대병원", "삼성서울병원"],
      "trustLevel": "medium",
      "prefixRequired": "~에 따르면"
    },
    "tier_3": {
      "description": "일반 건강 미디어",
      "examples": ["네이버 건강"],
      "trustLevel": "low",
      "prefixRequired": "일반적으로 알려진 바로는"
    },
    "tier_4": {
      "description": "출처 불명 / 민간요법 / SNS",
      "trustLevel": "reject",
      "action": "do_not_use"
    }
  },
  "disclaimers": {
    "general": {
      "narration": "본 영상은 일반적인 건강 정보를 다루고 있습니다",
      "position": "last_scene"
    },
    "consult_professional": {
      "narration": "개인차가 있을 수 있으며, 전문의 상담을 권장합니다",
      "position": "last_scene"
    },
    "description_footer": {
      "text": "⚠️ 본 영상은 의학적 조언이 아닌 일반 정보 제공 목적입니다. 건강 관련 결정은 반드시 전문의와 상담하세요.",
      "position": "youtube_description_bottom"
    }
  },
  "auditActions": {
    "allowed": "무조건 허용 (level_1)",
    "allowed_with_disclaimer": "허용 + 면책 (level_2)",
    "allowed_with_suffix_and_disclaimer": "허용 + 접미사 + 면책 (level_3)",
    "rewritten": "금지 감지 → 자동 재작성 (level_4 / 금지사전)",
    "blocked": "자동 재작성 불가 → 삭제 또는 사용자 수정 요청"
  }
}
